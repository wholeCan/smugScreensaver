<Window x:Class="andyScreenSaver.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmugAndy"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStyle="None"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown"
        Background="Black"
        Height="333"
        MouseMove="Window_MouseMove"
        Closed="Window_Closed"
        SizeChanged="Window_SizeChanged_1"
        Width="486"
        MouseRightButtonUp="Window_MouseRightButtonUp">

    <Grid Name="grid1" MouseUp="Image1_MouseUp">
        <Border BorderThickness="5" BorderBrush="Black">
            <UniformGrid Name="imageGrid" />
        </Border>

        <Label Name="SetupRequired"
               Background="Black"
               Foreground="LightGreen"
               MaxWidth="500"
               MaxHeight="650"
               VerticalAlignment="Top"
               HorizontalAlignment="Left"
               Opacity="0.8">
            Loading first image...
        </Label>
    </Grid>
</Window>
